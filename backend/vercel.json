{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/doctors/:id",
      "destination": "/api/doctors.js?id=:id"
    },
    {
      "source": "/api/appointments/:refId",
      "destination": "/api/appointments.js?refId=:refId"
    },
    {
      "source": "/api/admin/appointments",
      "destination": "/api/admin/appointments.js"
    },
    {
      "source": "/api/booked-slots",
      "destination": "/api/booked-slots.js"
    },
    {
      "source": "/api/doctors",
      "destination": "/api/doctors.js"
    },
    {
      "source": "/api/appointments",
      "destination": "/api/appointments.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/$1"
    }
  ]
}
